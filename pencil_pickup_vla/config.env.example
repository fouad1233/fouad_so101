# Copy this file to `config.env` and fill in your values. The shell scripts `source` it.
#   cp config.env.example config.env   &&   nano config.env

# Your Hugging Face username (datasets + models are stored on the HF Hub).
HF_USER=your-hf-username

# SO-101 serial ports (from `lerobot-find-port`; see ../myport.txxt).
FOLLOWER_PORT=/dev/tty.usbmodem5B421352311
LEADER_PORT=/dev/tty.usbmodem5B420006171
# Calibration ids you used with `lerobot-calibrate`.
FOLLOWER_ID=my_follower
LEADER_ID=my_leader

# Camera (run ./find_camera.sh to get the index). Keep the SAME camera/position/index
# for both recording AND autonomous running.
CAMERA_INDEX=0
CAMERA_W=640
CAMERA_H=480
CAMERA_FPS=30

# Where the dataset and the fine-tuned model live on the HF Hub.
DATASET_REPO=${HF_USER}/so101_pencil_pickup
MODEL_REPO=${HF_USER}/smolvla_pencil_pickup

# The task description. It MUST be identical at record time and inference time.
TASK="Pick up the pen and place it on the black mouse pad"

# Recording settings.
NUM_EPISODES=50      # ~50 varied demos is a good starting point for one task
EPISODE_TIME_S=20    # seconds per demonstration
RESET_TIME_S=10      # pause to reset the scene between demos
